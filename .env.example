# Copy this file to .env and fill in your own values.
# `.env` is gitignored and will never be committed.

# Where soccerdata should cache scraped data (absolute path recommended on Windows).
# If unset, soccerdata uses its default user-home cache directory.
SOCCERDATA_DIR=

# Logging level: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# Default competition to target. World Cup by default; can be e.g. "ENG-Premier League".
DEFAULT_COMPETITION=FIFA World Cup
DEFAULT_SEASON=2022
